# This is a demo config to showcase some of the most important commands.
# It is meant to be changed and configured, as it is intentionally kept sparse.
# For a (much) more advanced configuration example see my dotfiles:
# https://github.com/FelixKratz/dotfiles

PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar Appearance #####
sketchybar --bar position=top height=48 blur_radius=30 color=0x40000000

##### Changing Defaults #####
default=(
  padding_left=5
  padding_right=5
  icon.font="FiraCode Nerd Font:Bold:20.0"
  label.font="FiraCode Nerd Font:Bold:17.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

##### Adding Right Items #####
sketchybar --add item clock right \
           --set clock update_freq=10 icon=  label.font="FiraCode Nerd Font:Bold:17.0" script="$PLUGIN_DIR/clock.sh" \
           --add item battery right \
           --set battery icon.font="FiraCode Nerd Font:Bold:21.0" \
                         label.font="FiraCode Nerd Font:Bold:17.0" \
                         update_freq=120 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

##### Aerospace Workspace Spaces #####
sketchybar --add event aerospace_workspace_change

# Letter mnemonic workspaces (always shown)
LETTER_WORKSPACES=("N" "P" "W" "C" "E" "T" "S" "M" "F")
for sid in "${LETTER_WORKSPACES[@]}"; do
  sketchybar --add item space.$sid left \
    --set space.$sid \
      icon="$sid" \
      icon.padding_left=8 \
      icon.padding_right=4 \
      label.font="FiraCode Nerd Font:Bold:25.0" \
      label.padding_right=8 \
      label.y_offset=1 \
      background.height=29 \
      background.corner_radius=6 \
      background.drawing=off \
      click_script="aerospace workspace $sid"
done

# Number workspaces 0-9 (hidden by default, shown by script when occupied)
for sid in $(seq 0 9); do
  sketchybar --add item space.$sid left \
    --set space.$sid \
      icon="$sid" \
      icon.padding_left=8 \
      icon.padding_right=4 \
      label.font="FiraCode Nerd Font:Bold:25.0" \
      label.padding_right=8 \
      label.y_offset=1 \
      background.height=29 \
      background.corner_radius=6 \
      background.drawing=off \
      drawing=off \
      click_script="aerospace workspace $sid"
done

# Only space.N gets the script — it updates all spaces in one pass
sketchybar --set space.N script="$PLUGIN_DIR/aerospace.sh" \
  --subscribe space.N aerospace_workspace_change

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
